{
  "name": "@catalyst/worker",
  "type": "module",
  "private": true,
  "exports": {
    "./app": "./src/app.ts",
    "./db/schema": "./src/db/schema.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "wrangler deploy --env=''",
    "dev": "wrangler dev",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "slack-cloudflare-workers": "^1.3.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.18",
    "@cloudflare/workers-types": "^4.20260207.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
