    "db:migrate:local": "wrangler d1 migrations apply emoji-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply emoji-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.9",
    "slack-cloudflare-workers": "^0.8.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260207.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.63.0"
  }
}
