# Copy to `mise.local.toml` and fill in values.

[env]

# ─── Slack — only if exercising Slack code paths locally ──────────────────────
# Needed for: `/api/slack/events` handler, the backfill script, `/backfill` workflow.
# SLACK_BOT_TOKEN = "xoxb-..."
# SLACK_SIGNING_SECRET = "..."

# ─── Frontend (Vite reads `VITE_*` from process.env) ──────────────────────────
# Optional. The frontend falls back to CF's always-passes test site key.
# VITE_TURNSTILE_SITE_KEY = "..."

# ─── Wrangler CLI auth (deploys + remote D1 commands) ─────────────────────────
# Generate at https://dash.cloudflare.com/profile/api-tokens with
# "Edit Cloudflare Workers" + "D1 Edit" permissions.
# CLOUDFLARE_API_TOKEN = "..."

# ─── Sentry sourcemap upload (optional, for `mise run deploy:*`) ──────────────
# Only needed if you run local force-deploys (`mise run deploy:worker`,
# `mise run deploy:site --pages`). Cloudflare Pages auto-deploys read the same
# vars from the Pages dashboard, and `wrangler secret put SENTRY_DSN` handles
# the worker runtime DSN — so the deploy tasks Just Work without these for the
# happy path. If either is missing, the sourcemap upload step is skipped.
# Token: https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
# The project slug is hardcoded per side (catalyst-web / catalyst-worker) — no
# SENTRY_PROJECT var, since one deploy uploads to both projects.
# SENTRY_AUTH_TOKEN = "..."
# SENTRY_ORG = "your-org-slug"
