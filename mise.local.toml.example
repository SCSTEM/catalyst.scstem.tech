# Copy to `mise.local.toml` and fill in values.

[env]

# ─── Slack — only if exercising Slack code paths locally ──────────────────────
# Needed for: `/api/slack/events` handler, the backfill script, `/backfill` workflow.
# SLACK_BOT_TOKEN = "xoxb-..."
# SLACK_SIGNING_SECRET = "..."

# ─── Frontend (Vite reads `VITE_*` from process.env) ──────────────────────────
# Per-env Turnstile site keys consumed by `deploy:site` / `deploy:web`. The
# selected value is exported as `VITE_TURNSTILE_SITE_KEY` and baked into the
# Vite bundle at build time. Without these, the frontend falls back to CF's
# always-passes test key — which the worker rejects in real deploys.
# VITE_TURNSTILE_SITE_KEY_STAGING = "1x00000000000000000000AA"
# VITE_TURNSTILE_SITE_KEY_PROD = "..."

# ─── Wrangler CLI auth (deploys + remote D1 commands) ─────────────────────────
# Generate at https://dash.cloudflare.com/profile/api-tokens with
# "Edit Cloudflare Workers" + "D1 Edit" permissions.
# CLOUDFLARE_API_TOKEN = "..."

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Two separate Sentry projects, two DSNs, kept apart purely by variable name:
#   VITE_SENTRY_DSN → web SPA (catalyst-web). Vite only bundles VITE_* vars, so
#                     this is the only DSN that can reach the browser.
#   SENTRY_DSN      → worker  (catalyst-api). Bridged into the worker's env by
#                     CLOUDFLARE_INCLUDE_PROCESS_ENV (set in mise.toml).
#
# Local dev (optional): set either/both to run Sentry against `mise run dev`.
# Events are tagged environment=development. Omit them → Sentry stays inert.
# VITE_SENTRY_DSN = "https://...@...ingest...sentry.io/<web-project-id>"
# SENTRY_DSN = "https://...@...ingest...sentry.io/<api-project-id>"
#
# Local force-deploys (`mise run deploy:site` / `deploy:web`): the web build
# HARD-FAILS unless VITE_SENTRY_DSN (above) AND both vars below are set — a
# bundle that ships the Sentry SDK but never inits it is worse than an obvious
# failure. Cloudflare Pages auto-deploys read the same three from the Pages
# dashboard. (The deployed worker's DSN is a `wrangler secret`, NOT this
# SENTRY_DSN, which only feeds local `wrangler dev` — see DEPLOY.md.)
# Auth token: https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
# The project slug is hardcoded per side (catalyst-web / catalyst-api) — no
# SENTRY_PROJECT var, since one deploy uploads to both projects.
# SENTRY_AUTH_TOKEN = "..."
# SENTRY_ORG = "your-org-slug"
