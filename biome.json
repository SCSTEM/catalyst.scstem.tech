{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "useUniqueElementIds": "off",
        "noUnusedImports": "warn"
      },
      "style": {
        "useImportType": "warn"
      },
      "suspicious": {
        "noUnknownAtRules": "off",
        "noArrayIndexKey": "info"
      },
      "a11y": "off"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "html": {
    "formatter": {
      "enabled": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dist/",
      "!.wrangler/",
      "!.claude/",
      "!.carson/",
      "!.types/",
      "!**/worker-configuration.d.ts",
      "!**/routeTree.gen.ts",
      "!packages/worker/migrations"
    ]
  },
  "overrides": [
    {
      "includes": ["**/wrangler.jsonc"],
      "json": {
        "formatter": {
          "trailingCommas": "none"
        }
      }
    }
  ]
}
