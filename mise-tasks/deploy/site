#!/usr/bin/env bash
#MISE description="Deploy: verify → migrate → worker + Pages [--no-pages to skip Pages] [staging (default)|prod]"
set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/../_helpers.sh"

DEPLOY_PAGES=true
ENV=""

for arg in "$@"; do
  case "$arg" in
    --no-pages) DEPLOY_PAGES=false ;;
    staging|prod)
      if [[ -n "$ENV" ]]; then
        echo "Error: multiple environments specified" >&2
        exit 1
      fi
      ENV="$arg"
      ;;
    *)
      echo "Usage: mise run deploy:site [staging|prod] [--no-pages]" >&2
      exit 1
      ;;
  esac
done

ENV="${ENV:-staging}"

require_clean_git "$ENV"
require_branch_for_env "$ENV"
if [[ "$ENV" == "prod" ]]; then
  require_prod_confirmation
fi

# Resolve wrangler flags once
if [[ "$ENV" == "staging" ]]; then
  WRANGLER_ENV="--env=staging"
  PAGES_BRANCH="--branch=staging"
else
  WRANGLER_ENV="--env=''"
  PAGES_BRANCH=""
fi

echo "==> [$ENV] Running quality checks..."
mise run verify

echo "==> [$ENV] Applying D1 migrations..."
cd packages/worker
# shellcheck disable=SC2086
bunx wrangler d1 migrations apply DB --remote $WRANGLER_ENV
cd "$REPO_ROOT"

echo "==> [$ENV] Deploying worker..."
cd packages/worker
deploy_worker_with_sentry "$WRANGLER_ENV"
cd "$REPO_ROOT"

if [[ "$DEPLOY_PAGES" == "true" ]]; then
  echo "==> [$ENV] Building web..."
  if [[ "$ENV" == "prod" ]]; then
    PAGES_BRANCH_NAME="main"
  else
    PAGES_BRANCH_NAME="staging"
  fi
  CF_PAGES_COMMIT_SHA=$(git rev-parse HEAD) \
  CF_PAGES_BRANCH="$PAGES_BRANCH_NAME" \
    bun --filter '@catalyst/web' build

  echo "==> [$ENV] Deploying pages..."
  # shellcheck disable=SC2086
  bunx wrangler pages deploy packages/web/dist \
    --project-name="$PAGES_PROJECT" $PAGES_BRANCH
fi

echo "==> [$ENV] Deploy complete!"
