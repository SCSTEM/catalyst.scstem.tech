#!/usr/bin/env bash
#MISE description="Deploy CF Worker [staging (default)|prod]"
#MISE depends=["verify"]
#MISE dir="packages/worker"
set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/../_helpers.sh"

ENV="${1:-staging}"

require_clean_git "$ENV"
require_branch_for_env "$ENV"

case "$ENV" in
  staging)
    deploy_worker_with_sentry "--env staging"
    ;;
  prod)
    require_prod_confirmation
    deploy_worker_with_sentry ""
    ;;
  *)
    echo "Usage: mise run deploy:worker [staging|prod]" >&2
    exit 1
    ;;
esac
