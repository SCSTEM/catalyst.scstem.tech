{
  "permissions": {
    "allow": [
      "Bash(bun run typecheck:*)",
      "Bash(bun run build:*)",
      "Bash(bun run check:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run check"
          }
        ]
      }
    ]
  }
}
